# Copy this to backend/.env and fill in values

# Path to your models directory on Mac (the folder containing piper/ and mmproj/)
MODELS_PATH=/Users/YOUR_USERNAME/strisakhi-models

# LLM server — llama-server running on Mac native
OLLAMA_BASE_URL=http://host.docker.internal:8080

# Database (leave as-is for local)
DATABASE_URL=sqlite:////app/nyay_vani.db
CHROMA_PERSIST_DIR=/app/chroma_db

# Admin (change PIN in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strisakhi2024

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173